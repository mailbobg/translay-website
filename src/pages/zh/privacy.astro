---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import LegalPage from '../../components/LegalPage.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'zh';
const i = t(lang);
---

<BaseLayout title="隐私政策 — Translay" description="Translay 隐私政策" lang={lang}>
  <Navbar lang={lang} nav={i.nav} />
  <LegalPage title="隐私政策" lastUpdated="最后更新: 2026年2月">
    <h2>概述</h2>
    <p>Translay（以下简称「我们」）致力于保护您的隐私。本隐私政策说明我们如何处理您在使用 Translay 应用程序时的信息。</p>

    <h2>我们收集的信息及使用方式</h2>
    <p>我们仅收集并提供服务所必需的信息：</p>
    <ul>
      <li><strong>仅设备端：</strong>截图与图片仅在本地经 OCR 处理，不会上传。</li>
      <li><strong>翻译：</strong>仅将 OCR 识别出的文本（不含图片）发送至翻译服务以提供翻译。</li>
      <li><strong>AI 追问功能：</strong>仅当您使用该功能时，在您同意后，我们会将下述数据发送给 DeepSeek。</li>
      <li><strong>使用次数：</strong>通过 iCloud 同步使用次数计数器以管理免费额度。我们不收集可识别个人身份的信息。</li>
    </ul>

    <h2>第三方 AI 服务 — 发送的数据与接收方</h2>
    <p>当您使用<strong> AI 追问</strong>功能时，应用可能会向<strong> DeepSeek</strong>（我们的第三方 AI 服务提供方）发送以下内容：</p>
    <ul>
      <li><strong>发送的数据：</strong>您输入的追问文本以及用于回答所需的翻译上下文（如原文与译文）。不会发送图片或截图。</li>
      <li><strong>接收方：</strong>DeepSeek。您启用功能并同意发送数据前，会在应用中看到该名称。</li>
      <li><strong>发送时机：</strong>仅在向您清楚说明并取得您的同意后发送。未经您同意，应用不会向 AI 服务发送数据。</li>
    </ul>
    <p>我们不会存储您的 AI 对话内容。与 DeepSeek 之间的传输采用加密通道（HTTPS/TLS）。我们与 DeepSeek 的协议要求其对您的数据提供同等或等效的保护，且不得将您的数据用于训练其模型。</p>

    <h2>信息收集与使用（细则）</h2>
    <h3>本地处理</h3>
    <p>Translay 的 OCR（光学字符识别）功能完全在您的设备上运行。您的截图和图片不会被上传到任何服务器。</p>

    <h3>翻译服务</h3>
    <p>为提供翻译功能，我们会将 OCR 识别出的文本（仅文本，不含图片）通过加密通道发送到翻译服务（DeepL）。这些文本不会被存储或用于其他目的。</p>

    <h3>AI 追问功能</h3>
    <p>当您使用 AI 追问功能时，应用会说明将发送哪些数据、发送给谁（DeepSeek），并在发送前征得您的同意。仅在您同意后，与翻译相关的文本才会通过加密通道发送至 DeepSeek。我们不会存储您的对话内容。</p>

    <h3>使用数据</h3>
    <p>我们仅通过 iCloud 同步您的使用次数计数器，用于管理免费额度。我们不收集、存储或分享任何个人身份信息。</p>

    <h2>数据安全</h2>
    <p>所有网络传输均使用 HTTPS/TLS 加密。我们不维护用户数据库，也不存储任何翻译内容或个人信息。</p>

    <h2>第三方服务</h2>
    <p>Translay 使用以下第三方服务：</p>
    <ul>
      <li><strong>DeepL</strong> — 翻译服务。仅发送 OCR 文本；不用于其他目的存储。</li>
      <li><strong>DeepSeek</strong> — 仅在您同意后用于 AI 追问功能。我们要求其对您的数据提供同等或等效保护，且不得用于训练模型。</li>
      <li><strong>Apple iCloud</strong> — 使用次数同步</li>
      <li><strong>Cloudflare</strong> — API 代理与安全</li>
    </ul>

    <h2>儿童隐私</h2>
    <p>Translay 不面向 13 岁以下的儿童，也不会有意收集儿童的个人信息。</p>

    <h2>变更</h2>
    <p>我们可能会不时更新本隐私政策。更新后的政策将在此页面发布。</p>

    <h2>联系我们</h2>
    <p>如果您对本隐私政策有任何疑问，请联系我们：<a href="mailto:support@translay.app" class="text-blue-primary hover:underline">support@translay.app</a></p>
  </LegalPage>
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
