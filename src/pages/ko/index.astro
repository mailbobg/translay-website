---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Features from '../../components/Features.astro';
import Pricing from '../../components/Pricing.astro';
import Statement from '../../components/Statement.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'ko';
const i = t(lang);
---

<BaseLayout title="Translay — 모든 화면을 번역" description="스크린샷으로 2초 만에 번역. 앱을 떠나지 않고. 15개 이상 언어. AI 기반." lang={lang}>
  <Navbar lang={lang} nav={i.nav} />
  <main>
    <Hero {...i.hero} />
    <HowItWorks {...i.how} />
    <Features {...i.features} />
    <Pricing {...i.pricing} />
    <Statement {...i.statement} />
  </main>
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
