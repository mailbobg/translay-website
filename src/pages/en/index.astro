---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Features from '../../components/Features.astro';
import AppShowcase from '../../components/AppShowcase.astro';
import Pricing from '../../components/Pricing.astro';
import Statement from '../../components/Statement.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'en';
const i = t(lang);
---

<BaseLayout
  title="Translay — iPhone Screen Translator App | Translate Any Screen in 2 Seconds"
  description="Translay is a free iOS screen translation app. Double-tap your iPhone's back to screenshot and translate text instantly. Supports 15+ languages with DeepL engine, AI follow-up questions, and on-device OCR for complete privacy."
  lang={lang}
>
  <Navbar lang={lang} nav={i.nav} />
  <main>
    <Hero lang={lang} {...i.hero} />
    <HowItWorks {...i.how} />
    <Features {...i.features} />
    <AppShowcase {...i.showcase} />
    <Pricing {...i.pricing} />
    <Statement {...i.statement} />
  </main>
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
