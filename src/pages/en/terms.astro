---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import LegalPage from '../../components/LegalPage.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'en';
const i = t(lang);
---

<BaseLayout title="Terms of Service — Translay" description="Translay Terms of Service" lang={lang}>
  <Navbar lang={lang} nav={i.nav} />
  <LegalPage title="Terms of Service" lastUpdated="Last updated: February 2026">
    <h2>Acceptance of Terms</h2>
    <p>By using Translay, you agree to these Terms of Service. If you do not agree, please stop using the application.</p>

    <h2>Service Description</h2>
    <p>Translay is a screen translation app that captures screenshots, recognizes text, and provides translations. Translation results are for reference only; we do not guarantee translation accuracy.</p>

    <h2>Free and Paid Services</h2>
    <p>Translay offers both free and Pro paid versions. The free version provides limited daily translations and AI questions. Pro is available via Apple in-app subscription for unlimited use.</p>
    <ul>
      <li>Subscriptions auto-renew annually</li>
      <li>Cancel at least 24 hours before the current period ends via Apple ID settings</li>
      <li>Refund policy follows Apple App Store guidelines</li>
    </ul>

    <h2>Usage Restrictions</h2>
    <p>You agree not to:</p>
    <ul>
      <li>Abuse or interfere with the service in any way</li>
      <li>Attempt to bypass free usage limits</li>
      <li>Use the service for any illegal purpose</li>
    </ul>

    <h2>Disclaimer</h2>
    <p>Translay is provided "as is." Translation results are generated by third-party translation engines and may not be perfectly accurate. We are not responsible for any losses resulting from the use of translation results.</p>

    <h2>Intellectual Property</h2>
    <p>Translay's trademarks, design, and code belong to their respective owners. Intellectual property of content translated through the app belongs to the original content owners.</p>

    <h2>Changes to Terms</h2>
    <p>We reserve the right to modify these terms at any time. Continued use of the service after changes constitutes acceptance of the modified terms.</p>

    <h2>Contact</h2>
    <p>Questions? Contact us at: <a href="mailto:support@translay.app" class="text-blue-primary hover:underline">support@translay.app</a></p>
  </LegalPage>
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
