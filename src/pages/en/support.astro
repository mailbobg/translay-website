---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import SupportContent from '../../components/SupportContent.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'en';
const i = t(lang);
---

<BaseLayout
  title="Help & FAQ — Translay Screen Translator App"
  description="Learn how to set up and use Translay, the iOS screen translation app. Includes quick setup guide, Back Tap shortcut configuration, translation troubleshooting, supported languages, and privacy information."
  lang={lang}
  faqSchema={i.support_page.faqs}
>
  <Navbar lang={lang} nav={i.nav} />
  <SupportContent lang={lang} support_page={i.support_page} />
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
