---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Features from '../../components/Features.astro';
import AppShowcase from '../../components/AppShowcase.astro';
import Pricing from '../../components/Pricing.astro';
import Statement from '../../components/Statement.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'ja';
const i = t(lang);
---

<BaseLayout
  title="Translay — iPhone 画面翻訳アプリ | スクリーンショットで 2 秒翻訳"
  description="Translay は iOS 画面翻訳アプリです。iPhone の背面をダブルタップするだけでスクリーンショット翻訳が完了。日本語・英語・中国語・韓国語など 15 以上の言語に対応し、DeepL エンジンと AI 質問機能を搭載。OCR はデバイス上で実行されプライバシーも安心。"
  lang={lang}
>
  <Navbar lang={lang} nav={i.nav} />
  <main>
    <Hero lang={lang} {...i.hero} />
    <HowItWorks {...i.how} />
    <Features {...i.features} />
    <AppShowcase {...i.showcase} />
    <Pricing {...i.pricing} />
    <Statement {...i.statement} />
  </main>
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
