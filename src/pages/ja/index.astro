---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Features from '../../components/Features.astro';
import Pricing from '../../components/Pricing.astro';
import Statement from '../../components/Statement.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'ja';
const i = t(lang);
---

<BaseLayout title="Translay — あらゆる画面を翻訳" description="スクリーンショットで2秒翻訳。アプリを離れずに。15以上の言語対応。AI搭載。" lang={lang}>
  <Navbar lang={lang} nav={i.nav} />
  <main>
    <Hero {...i.hero} />
    <HowItWorks {...i.how} />
    <Features {...i.features} />
    <Pricing {...i.pricing} />
    <Statement {...i.statement} />
  </main>
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
