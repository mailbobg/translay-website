---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import SupportContent from '../../components/SupportContent.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'ja';
const i = t(lang);
---

<BaseLayout title="サポート — Translay" description="Translayのヘルプとよくある質問" lang={lang}>
  <Navbar lang={lang} nav={i.nav} />
  <SupportContent lang={lang} support_page={i.support_page} />
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
