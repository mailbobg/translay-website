---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import SupportContent from '../../components/SupportContent.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';

const lang = 'ja';
const i = t(lang);
---

<BaseLayout
  title="ヘルプ・よくある質問 — Translay 画面翻訳アプリ"
  description="Translay 画面翻訳アプリの設定方法と使い方をご紹介。クイックセットアップガイド、背面タップのショートカット設定、翻訳トラブルシューティング、対応言語一覧、プライバシー情報を掲載。"
  lang={lang}
  faqSchema={i.support_page.faqs}
>
  <Navbar lang={lang} nav={i.nav} />
  <SupportContent lang={lang} support_page={i.support_page} />
  <Footer lang={lang} footer={i.footer} />
</BaseLayout>
