---
import PhoneFrame from './PhoneFrame.astro';

interface ShowcaseItem {
  src: string;
  title: string;
  desc: string;
}

interface Props {
  label: string;
  items: ShowcaseItem[];
}

const { label, items } = Astro.props;
---

<section id="showcase" class="py-24 lg:py-32 overflow-hidden">
  <div class="mx-auto max-w-6xl px-6">
    <div data-reveal="scale" class="mb-16 section-line">
      <h2 class="text-xs font-mono tracking-widest text-text-ghost uppercase">{label}</h2>
    </div>
  </div>

  <!-- Horizontal scroll gallery with 3D perspective -->
  <div class="relative" style="perspective: 1200px;">
    <div class="flex gap-10 overflow-x-auto pb-8 px-6 lg:px-[calc((100vw-72rem)/2+1.5rem)] snap-x snap-mandatory scrollbar-hide">
      {items.map((item, i) => (
        <div
          data-reveal="rotate"
          class="snap-center shrink-0 flex flex-col items-center gap-5 showcase-item"
          style={`transition-delay: ${i * 0.15}s`}
        >
          <div class="relative">
            <PhoneFrame
              src={item.src}
              alt={item.title}
              class="w-[220px] sm:w-[250px]"
            />
            <!-- Glow under each phone -->
            <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-3/4 h-8 bg-blue-primary/10 blur-2xl rounded-full"></div>
          </div>
          <div class="text-center max-w-[260px]">
            <h3 class="text-base font-semibold mb-1">{item.title}</h3>
            <p class="text-xs text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Scroll fade edges — wider for drama -->
    <div class="absolute top-0 left-0 bottom-8 w-20 bg-gradient-to-r from-bg-deep via-bg-deep/80 to-transparent pointer-events-none"></div>
    <div class="absolute top-0 right-0 bottom-8 w-20 bg-gradient-to-l from-bg-deep via-bg-deep/80 to-transparent pointer-events-none"></div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
