---
const steps = [
  { num: '1', title: '截屏', desc: '连按手机背面触发' },
  { num: '2', title: '翻译', desc: 'AI 自动识别 + DeepL 翻译' },
  { num: '3', title: '查看', desc: '译文精准覆盖原文位置' },
];
---

<section class="py-24 px-6 bg-bg-gray">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-text-main mb-16 animate-in-view step-card" data-stagger="0">工作流程</h2>
    <div class="flex flex-col md:flex-row items-stretch justify-center gap-6 md:gap-4">
      {steps.map((step, i) => (
        <div
          class="animate-in-view step-card rounded-card-xl bg-bg-light p-8 shadow-sm border border-gray-200/80 text-center flex-1 min-w-0"
          data-stagger={i}
        >
          <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl font-bold text-primary">
            {step.num}
          </div>
          <h3 class="text-xl font-semibold text-text-main mb-2">{step.title}</h3>
          <p class="text-text-muted">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
