---
interface PricingPlan {
  name: string;
  features: string[];
  price: string;
  cta: string;
  badge?: string;
  period?: string;
}

interface Props {
  label: string;
  free: PricingPlan;
  pro: PricingPlan;
}

const { label, free, pro } = Astro.props;
---

<section id="pricing" class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div data-reveal class="mb-16 section-line">
      <h2 class="text-xs font-mono tracking-widest text-text-ghost uppercase">{label}</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-8 max-w-3xl mx-auto" style="perspective: 1000px;">
      <!-- Free plan -->
      <div data-reveal="left" class="relative p-8 rounded-2xl border border-white/5 bg-white/[0.02] hover-lift pricing-glow tilt-card" data-tilt data-tilt-max="6">
        <h3 class="text-2xl font-bold mb-6">{free.name}</h3>

        <ul class="space-y-3 mb-8">
          {free.features.map((f) => (
            <li class="flex items-center gap-3 text-sm text-text-secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-ghost shrink-0">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <div class="mb-6">
          <span class="text-4xl font-bold">{free.price}</span>
        </div>

        <a
          href="#"
          class="magnetic-hover inline-flex items-center justify-center w-full py-3 rounded-full border border-white/10 text-sm font-medium hover:bg-white/5 hover:border-white/20 transition-all duration-500"
        >
          {free.cta}
        </a>
      </div>

      <!-- Pro plan — with breathing glow + rotating border -->
      <div data-reveal="right" class="relative p-8 rounded-2xl border border-border-blue bg-blue-primary/[0.04] glow-blue-breathe hover-lift pricing-glow tilt-card" data-tilt data-tilt-max="6">
        <!-- Badge -->
        <div class="absolute top-6 right-6">
          <span class="text-[10px] font-mono font-bold tracking-widest bg-blue-primary text-white px-3 py-1.5 rounded-full shadow-lg shadow-blue-primary/30">
            {pro.badge}
          </span>
        </div>

        <h3 class="text-2xl font-bold mb-6">{pro.name}</h3>

        <ul class="space-y-3 mb-8">
          {pro.features.map((f) => (
            <li class="flex items-center gap-3 text-sm text-text-secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-primary shrink-0">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <div class="mb-6">
          <span class="text-4xl font-bold">{pro.price}</span>
          {pro.period && <span class="text-sm text-text-ghost ml-1">{pro.period}</span>}
        </div>

        <a
          href="#"
          class="magnetic-hover inline-flex items-center justify-center w-full py-3.5 rounded-full bg-blue-primary hover:bg-blue-primary/90 text-sm font-semibold transition-all duration-500 hover:shadow-xl hover:shadow-blue-primary/30 hover:scale-[1.02] active:scale-[0.98]"
        >
          {pro.cta}
        </a>
      </div>
    </div>
  </div>
</section>
