---
const title = '翻译任何屏幕，不离开当前 App';
const subtitle = '截屏 → 翻译 → 2 秒完成，沉浸式覆盖原文';
const ctaText = 'Download on the App Store';
---

<section class="min-h-screen flex flex-col md:flex-row items-center justify-center gap-12 md:gap-16 px-6 py-20 bg-hero-gradient relative overflow-hidden">
  <div class="relative z-10 max-w-xl mx-auto md:mx-0 text-center md:text-left">
    <h1 class="animate-in-view hero-title text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
      {title}
    </h1>
    <p class="animate-in-view hero-sub text-lg md:text-xl text-white/90 mb-10">
      {subtitle}
    </p>
    <a
      href="#"
      class="animate-in-view hero-cta cta-hover inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-primary font-semibold rounded-2xl shadow-lg"
      aria-label={ctaText}
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      {ctaText}
    </a>
  </div>
  <div class="relative z-10 flex justify-center">
    <!-- iPhone mockup 占位：入场动画 + 持续浮动 -->
    <div class="animate-in-view hero-mockup hero-mockup-float w-64 md:w-72 aspect-[9/19] bg-black/40 backdrop-blur rounded-[2.5rem] border-[10px] border-gray-800 shadow-2xl flex items-center justify-center">
      <span class="text-white/60 text-sm">iPhone Mockup</span>
    </div>
  </div>
</section>
