---
import type { Lang } from '../i18n/index';

interface Props {
  lang: Lang;
  title_1: string;
  title_2: string;
  subtitle: string;
  cta: string;
  cta_sub: string;
}

const { lang, title_1, title_2, subtitle, cta, cta_sub } = Astro.props;

// Use language-appropriate screenshot
const heroScreenshot = lang === 'zh' ? '/screenshots/home-zh.png' : '/screenshots/home-en.png';

const heroAlts: Record<string, string> = {
  zh: 'Translay 屏幕翻译 App 首页截图',
  en: 'Translay screen translator app home screen',
  ja: 'Translay 画面翻訳アプリのホーム画面',
  ko: 'Translay 화면 번역 앱 홈 화면',
};
const heroAlt = heroAlts[lang] || heroAlts.en;
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">
  <!-- Background glows (parallax) -->
  <div data-parallax="-0.12" class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-blue-primary/5 blur-[120px] pointer-events-none"></div>
  <div data-parallax="0.08" class="absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full bg-blue-primary/3 blur-[100px] pointer-events-none"></div>

  <div class="mx-auto max-w-6xl px-6 w-full grid lg:grid-cols-2 gap-12 lg:gap-16 items-center py-20 lg:py-0">
    <!-- Text content -->
    <div class="space-y-8">
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.08] tracking-tight">
        <span class="animate-fade-in-up block">{title_1}</span>
        <span class="animate-fade-in-up animate-delay-200 block text-blue-light">{title_2}</span>
      </h1>

      <p class="animate-fade-in-up animate-delay-300 text-lg sm:text-xl text-text-secondary max-w-md">
        {subtitle}
      </p>

      <!-- App Store badge -->
      <div class="animate-fade-in-up animate-delay-400 flex flex-col sm:flex-row items-start gap-4">
        <a
          href="#"
          class="inline-block transition-transform hover:scale-105 active:scale-[0.98]"
          aria-label="Download on the App Store"
        >
          <img
            src="/app-store-badge.svg"
            alt="Download on the App Store"
            width="160"
            height="54"
            class="h-[54px] w-auto"
          />
        </a>
      </div>

      <p class="animate-fade-in-up animate-delay-500 text-xs font-mono text-text-ghost">
        {cta_sub}
      </p>
    </div>

    <!-- iPhone mockup with real screenshot -->
    <div class="animate-fade-in animate-delay-300 relative flex justify-center lg:justify-end">
      <div class="relative animate-float">
        <!-- iPhone device frame -->
        <div class="relative w-[280px] sm:w-[300px] mx-auto">
          <!-- Outer frame -->
          <div class="relative rounded-[3rem] border-[6px] border-[#1a1a2e] bg-[#1a1a2e] shadow-2xl shadow-black/40 overflow-hidden">
            <!-- Dynamic Island notch -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 z-20 w-[100px] h-[28px] bg-[#1a1a2e] rounded-b-2xl"></div>

            <!-- Screenshot -->
            <img
              src={heroScreenshot}
              alt={heroAlt}
              class="w-full h-auto rounded-[2.4rem]"
              loading="eager"
            />

            <!-- Bottom bar indicator -->
            <div class="absolute bottom-2 left-1/2 -translate-x-1/2 w-[120px] h-[4px] bg-white/20 rounded-full z-20"></div>
          </div>

          <!-- Glow behind phone -->
          <div class="absolute -inset-8 bg-blue-primary/8 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
