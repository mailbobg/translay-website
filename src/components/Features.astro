---
import PhoneFrame from './PhoneFrame.astro';

interface Feature {
  title: string;
  desc: string;
  screenshot?: string;
  screenshot_alt?: string;
}

interface Props {
  label: string;
  items: Feature[];
}

const { label, items } = Astro.props;

const icons = [
  // Layers (immersive overlay)
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/></svg>`,
  // Globe (languages)
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  // Sparkles (AI)
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>`,
  // Shield (privacy)
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`,
];
---

<section id="features" class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div data-reveal class="mb-20 section-line">
      <h2 class="text-xs font-mono tracking-widest text-text-ghost uppercase">{label}</h2>
    </div>

    <div class="space-y-32 lg:space-y-40">
      {items.map((item, i) => {
        const isReversed = i % 2 === 1;
        const hasScreenshot = !!item.screenshot;
        const textDirection = isReversed ? 'right' : 'left';
        const imgDirection = isReversed ? 'left' : 'right';

        return (
          <div
            class:list={[
              "grid gap-12 lg:gap-20 items-center",
              hasScreenshot ? "lg:grid-cols-2" : "lg:grid-cols-1 max-w-2xl"
            ]}
          >
            {/* Text side */}
            <div
              data-reveal={hasScreenshot ? textDirection : ''}
              class:list={[hasScreenshot && isReversed && "lg:order-2"]}
            >
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-blue-primary/10 text-blue-light mb-6 group-hover:scale-110 transition-transform duration-500">
                <Fragment set:html={icons[i]} />
              </div>
              <h3 class="text-3xl sm:text-4xl font-bold mb-5">{item.title}</h3>
              <p class="text-base sm:text-lg text-text-secondary leading-relaxed max-w-lg">{item.desc}</p>
            </div>

            {/* Screenshot side — with 3D hover */}
            {hasScreenshot && (
              <div
                data-reveal={imgDirection}
                class:list={[
                  "flex justify-center",
                  isReversed && "lg:order-1"
                ]}
                style="perspective: 800px;"
              >
                <div class="showcase-item">
                  <PhoneFrame
                    src={item.screenshot!}
                    alt={item.screenshot_alt || item.title}
                    class="w-[220px] sm:w-[260px]"
                  />
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
