---
interface Feature {
  title: string;
  desc: string;
}

interface Props {
  label: string;
  items: Feature[];
}

const { label, items } = Astro.props;

const icons = [
  // Layers (immersive overlay)
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/></svg>`,
  // Globe (languages)
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  // Sparkles (AI)
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>`,
  // Shield (privacy)
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>`,
];
---

<section id="features" class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div data-reveal class="mb-16">
      <span class="text-xs font-mono tracking-widest text-text-ghost uppercase">{label}</span>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      {items.map((item, i) => (
        <div
          data-reveal
          class="group relative p-8 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] hover:border-border-blue transition-all duration-500"
          style={`transition-delay: ${i * 0.1}s`}
        >
          <!-- Icon -->
          <div class="mb-5 inline-flex items-center justify-center w-11 h-11 rounded-xl bg-blue-primary/10 text-blue-light group-hover:bg-blue-primary/15 transition-colors">
            <Fragment set:html={icons[i]} />
          </div>

          <!-- Title -->
          <h3 class="text-lg font-semibold mb-2">{item.title}</h3>

          <!-- Description -->
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
