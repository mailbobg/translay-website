---
const cases = [
  { emoji: '📱', label: '游戏', title: '日文游戏界面', sub: '中文翻译' },
  { emoji: '🛒', label: '购物', title: '韩文电商页面', sub: '中文翻译' },
  { emoji: '🗺️', label: '出行', title: '德文地图/导航', sub: '中文翻译' },
  { emoji: '💬', label: '社交', title: '英文社交 App', sub: '中文翻译' },
];
---

<section class="py-24 px-6 bg-bg-gray overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-text-main mb-12 animate-in-view use-case-card" data-stagger="0">使用场景</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {cases.map((c, i) => (
        <div
          class="animate-in-view use-case-card rounded-card-xl bg-bg-light p-6 border border-gray-200/60 shadow-sm"
          data-stagger={i}
        >
          <span class="text-2xl mb-3 block" aria-hidden="true">{c.emoji}</span>
          <p class="text-sm font-medium text-primary mb-1">{c.label}</p>
          <p class="text-text-main font-medium">{c.title}</p>
          <p class="text-text-muted text-sm">→ {c.sub}</p>
        </div>
      ))}
    </div>
  </div>
</section>
