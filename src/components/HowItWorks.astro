---
interface Step {
  num: string;
  title: string;
  desc: string;
  screenshot?: string;
}

interface Props {
  label: string;
  steps: Step[];
}

const { label, steps } = Astro.props;

const icons = [
  // Tap icon
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 13"/></svg>`,
  // Translate icon
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>`,
  // Chat icon
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>`,
];
---

<section id="how-it-works" class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div data-reveal class="mb-16 section-line">
      <h2 class="text-xs font-mono tracking-widest text-text-ghost uppercase">{label}</h2>
    </div>

    <div data-stagger class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step, i) => (
        <div class="group relative" style="perspective: 800px;">
          <!-- Card with 3D tilt -->
          <div class="relative p-8 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.05] hover:border-blue-primary/20 transition-all duration-500 hover-lift tilt-card" data-tilt data-tilt-max="8">
            <!-- Step number — big and bold -->
            <span class="text-6xl font-black text-blue-primary/20 group-hover:text-blue-primary/50 transition-all duration-500 group-hover:scale-110 inline-block">{step.num}</span>

            <!-- Icon with pulse on hover -->
            <div class="mt-4 mb-4 text-blue-light/70 group-hover:text-blue-light transition-colors duration-500" set:html={icons[i]} />

            <!-- Title -->
            <h3 class="text-xl font-semibold mb-3">{step.title}</h3>

            <!-- Description -->
            <p class="text-sm text-text-secondary leading-relaxed">{step.desc}</p>

            <!-- Optional screenshot thumbnail -->
            {step.screenshot && (
              <div class="mt-6 rounded-xl overflow-hidden border border-white/5 group-hover:border-blue-primary/15 transition-colors">
                <img
                  src={step.screenshot}
                  alt={step.title}
                  class="w-full h-auto opacity-70 group-hover:opacity-100 group-hover:scale-[1.03] transition-all duration-700"
                  loading="lazy"
                />
              </div>
            )}

            <!-- Card glow on hover -->
            <div class="absolute inset-0 rounded-2xl bg-blue-primary/0 group-hover:bg-blue-primary/[0.02] transition-colors duration-500 pointer-events-none"></div>
          </div>

          {/* Connector line between cards — animated glow */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-1/2 -right-6 lg:-right-6 w-8 lg:w-12">
              <div class="h-px bg-gradient-to-r from-blue-primary/20 via-blue-light/30 to-transparent"></div>
              <div class="h-px mt-px bg-gradient-to-r from-blue-primary/5 via-blue-light/10 to-transparent blur-sm"></div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
