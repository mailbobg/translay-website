---
interface Step {
  num: string;
  title: string;
  desc: string;
}

interface Props {
  label: string;
  steps: Step[];
}

const { label, steps } = Astro.props;

const icons = [
  // Tap icon
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 13"/></svg>`,
  // Translate icon
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>`,
  // Chat icon
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>`,
];
---

<section id="how-it-works" class="py-24 lg:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div data-reveal class="mb-16">
      <span class="text-xs font-mono tracking-widest text-text-ghost uppercase">{label}</span>
    </div>

    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step, i) => (
        <div data-reveal class="group relative" style={`transition-delay: ${i * 0.15}s`}>
          <!-- Card -->
          <div class="relative p-8 rounded-2xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] hover:border-white/10 transition-all duration-500">
            <!-- Step number -->
            <span class="text-5xl font-bold text-blue-primary/40 group-hover:text-blue-primary/60 transition-colors">{step.num}</span>

            <!-- Icon -->
            <div class="mt-4 mb-4 text-blue-light/70" set:html={icons[i]} />

            <!-- Title -->
            <h3 class="text-xl font-semibold mb-3">{step.title}</h3>

            <!-- Description -->
            <p class="text-sm text-text-secondary leading-relaxed">{step.desc}</p>
          </div>

          {/* Connector line between cards */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-1/2 -right-6 lg:-right-6 w-8 lg:w-12 h-px bg-gradient-to-r from-white/10 to-transparent"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
