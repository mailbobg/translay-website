---
import type { Lang } from '../i18n/index';

interface Props {
  lang: Lang;
  footer: {
    support: string;
    privacy: string;
    terms: string;
    copyright: string;
  };
}

const { lang, footer } = Astro.props;
---

<footer class="border-t border-white/5 py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <!-- Left: Logo + copyright -->
      <div class="flex items-center gap-6">
        <a href={`/${lang}/`} class="flex items-center gap-2">
          <div class="w-5 h-5 rounded-full bg-blue-primary"></div>
          <span class="text-sm font-medium text-text-secondary">translay</span>
        </a>
        <span class="text-xs text-text-ghost">{footer.copyright}</span>
      </div>

      <!-- Right: Links -->
      <div class="flex items-center gap-6">
        <a href={`/${lang}/support`} class="text-xs text-text-ghost hover:text-text-secondary transition-colors">{footer.support}</a>
        <a href={`/${lang}/privacy`} class="text-xs text-text-ghost hover:text-text-secondary transition-colors">{footer.privacy}</a>
        <a href={`/${lang}/terms`} class="text-xs text-text-ghost hover:text-text-secondary transition-colors">{footer.terms}</a>
      </div>
    </div>
  </div>
</footer>
