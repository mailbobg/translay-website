---
import { languages, type Lang } from '../i18n/index';

interface Props {
  lang: Lang;
  nav: { features: string; pricing: string; support: string };
}

const { lang, nav } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 backdrop-blur-xl bg-[#0A0A0F]/80">
  <div class="mx-auto max-w-6xl px-6 h-20 flex items-center justify-between">
    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center gap-2.5 group">
      <img
        src="/logo.svg"
        alt="Translay"
        width="56"
        height="56"
        class="w-14 h-14 rounded-xl transition-transform group-hover:scale-110"
      />
      <span class="text-3xl font-semibold tracking-[0.02em]">
        <span class="text-white">trans</span><span class="text-blue-light">lay</span>
      </span>
    </a>

    <!-- Center nav -->
    <div class="hidden md:flex items-center gap-8">
      <a href={`/${lang}/#features`} class="text-sm text-text-secondary hover:text-white transition-colors">{nav.features}</a>
      <a href={`/${lang}/#pricing`} class="text-sm text-text-secondary hover:text-white transition-colors">{nav.pricing}</a>
      <a href={`/${lang}/support`} class="text-sm text-text-secondary hover:text-white transition-colors">{nav.support}</a>
    </div>

    <!-- Right: language switcher + CTA -->
    <div class="flex items-center gap-4">
      <!-- Language switcher -->
      <div class="relative group">
        <button class="text-xs font-mono text-text-ghost hover:text-text-secondary transition-colors px-2 py-1 rounded border border-transparent hover:border-border">
          {languages[lang]}
        </button>
        <div class="absolute right-0 top-full mt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all bg-bg-card border border-border rounded-lg py-1 min-w-[100px] shadow-xl">
          {Object.entries(languages).map(([code, name]) => (
            <a
              href={`/${code}/`}
              class:list={[
                "block px-4 py-1.5 text-xs hover:bg-white/5 transition-colors",
                code === lang ? "text-blue-primary" : "text-text-secondary"
              ]}
            >
              {name}
            </a>
          ))}
        </div>
      </div>

      <!-- Mobile menu -->
      <button class="md:hidden text-text-secondary hover:text-white" id="mobile-menu-btn" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="md:hidden hidden border-t border-white/5 bg-[#0A0A0F]/95 backdrop-blur-xl">
    <div class="px-6 py-4 flex flex-col gap-3">
      <a href={`/${lang}/#features`} class="text-sm text-text-secondary py-1">{nav.features}</a>
      <a href={`/${lang}/#pricing`} class="text-sm text-text-secondary py-1">{nav.pricing}</a>
      <a href={`/${lang}/support`} class="text-sm text-text-secondary py-1">{nav.support}</a>
      <div class="border-t border-white/5 pt-3 flex gap-3">
        {Object.entries(languages).map(([code, name]) => (
          <a
            href={`/${code}/`}
            class:list={[
              "text-xs px-2 py-1 rounded",
              code === lang ? "text-blue-primary bg-blue-subtle" : "text-text-ghost"
            ]}
          >
            {name}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    nav?.classList.toggle('hidden');
  });
</script>
