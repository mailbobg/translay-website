---
interface Props {
  line1: string;
  line2: string;
  sub: string;
}

const { line1, line2, sub } = Astro.props;
---

<section class="py-32 lg:py-48 relative overflow-hidden">
  <!-- Dramatic glow (parallax) -->
  <div data-parallax="-0.12" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full bg-blue-primary/6 blur-[160px] pointer-events-none"></div>
  <div data-parallax="0.06" class="absolute left-1/4 top-1/3 w-[400px] h-[400px] rounded-full bg-blue-glow/4 blur-[120px] pointer-events-none"></div>

  <div class="mx-auto max-w-6xl px-6 relative">
    <div data-reveal="blur">
      <h2 class="text-5xl sm:text-6xl lg:text-8xl font-bold leading-[1.05] tracking-tight mb-8">
        <span class="block">{line1}</span>
        <span class="block hero-glow-text animate-gradient-text" style="background-image: linear-gradient(90deg, #4DA3FF, #007AFF, #4DA3FF, #0050B4, #4DA3FF);">{line2}</span>
      </h2>
      <p class="text-lg sm:text-xl text-text-secondary max-w-lg">{sub}</p>
    </div>
  </div>

  <!-- Decorative lines -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-primary/10 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-primary/10 to-transparent"></div>
</section>
