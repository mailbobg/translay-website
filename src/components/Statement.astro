---
interface Props {
  line1: string;
  line2: string;
  sub: string;
}

const { line1, line2, sub } = Astro.props;
---

<section class="py-24 lg:py-40 relative overflow-hidden">
  <!-- Subtle glow (parallax) -->
  <div data-parallax="-0.08" class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-blue-primary/4 blur-[100px] pointer-events-none"></div>

  <div class="mx-auto max-w-6xl px-6 relative">
    <div data-reveal="blur">
      <h2 class="text-4xl sm:text-5xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
        <span class="block">{line1}</span>
        <span class="block text-blue-light">{line2}</span>
      </h2>
      <p class="text-lg text-text-secondary max-w-lg">{sub}</p>
    </div>
  </div>
</section>
